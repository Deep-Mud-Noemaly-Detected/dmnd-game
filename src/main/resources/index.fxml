<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="controller.GameController">
    <padding>
        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0"/>
    </padding>

    <top>
        <Label fx:id="statusLabel" text="Chargement de la carte..." BorderPane.alignment="CENTER_LEFT"/>
    </top>

    <center>
        <StackPane fx:id="gameContainer" style="-fx-background-color: #0b0b0b;" BorderPane.alignment="CENTER">
            <StackPane fx:id="startOverlay" style="-fx-background-color: rgba(0,0,0,0.85);">
                <VBox alignment="CENTER" spacing="14.0" maxWidth="900.0">
                    <ImageView fx:id="startImageView" fitWidth="760.0" preserveRatio="true"/>
                    <HBox alignment="CENTER" spacing="10.0">
                        <Label text="Nombre de clients" style="-fx-text-fill: white;"/>
                        <Spinner fx:id="clientsSpinner" prefWidth="90.0"/>
                    </HBox>
                </VBox>
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
